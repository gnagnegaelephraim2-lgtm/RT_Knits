# NITA CMMS — Server Configuration
# Copy this file to .env and fill in real values.

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Server bind port (default: 8080)
SERVER_PORT=8080

# Comma-separated allowed origins for CORS (use * for development)
ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.vercel.app
